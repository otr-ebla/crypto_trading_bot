# ─── Exchange Configuration ───
EXCHANGE_ID=kucoin
EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_API_SECRET=your_api_secret_here
EXCHANGE_SANDBOX=true

# ─── Trading Configuration ───
TRADING_MODE=paper
TRADING_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT
TRADING_TIMEFRAME=1h
TRADING_INTERVAL_SECONDS=60

# ─── Risk Management ───
RISK_MAX_POSITION_PCT=5.0
RISK_STOP_LOSS_PCT=3.0
RISK_TAKE_PROFIT_PCT=6.0
RISK_MAX_DAILY_DRAWDOWN_PCT=10.0
RISK_MAX_CONSECUTIVE_LOSSES=3
RISK_COOLDOWN_MINUTES=30
PAPER_STARTING_BALANCE=10000.0

# ─── Sentiment / News ───
NEWS_API_KEY=your_newsapi_key_here
NEWS_ENABLED=true
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=TradingBot/0.1
REDDIT_ENABLED=false

# ─── Database ───
DATABASE_URL=sqlite:///tradingbot.db

# ─── Logging ───
LOG_LEVEL=INFO
LOG_FILE=logs/tradingbot.log

# ─── Dashboard ───
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8080
DASHBOARD_TOKEN=albertopaulaner456^
